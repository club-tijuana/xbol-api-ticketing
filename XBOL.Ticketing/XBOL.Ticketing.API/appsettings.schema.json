{
  "allOf": [
    {
      "$ref": "https://json.schemastore.org/appsettings.json"
    }
  ],
  "properties": {
    "SeatsIoApi": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "SecretKey": {
          "type": "string",
          "description": "Seats.io workspace secret key"
        },
        "Region": {
          "type": "string",
          "description": "Seats.io API region identifier (e.g. NA, EU, SA, OC)",
          "default": "NA"
        },
        "HoldExpirationInMinutes": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Hold token expiration in minutes. When null, uses the default configured in the Seats.io dashboard."
        }
      },
      "description": "Seats.io API configuration"
    }
  },
  "type": "object"
}