{
  "allOf": [
    {
      "$ref": "https://json.schemastore.org/appsettings.json"
    }
  ],
  "properties": {
    "SeatsIoApi": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "SecretKey": {
          "type": "string",
          "description": "Seats.io workspace secret key"
        },
        "Region": {
          "type": "string",
          "description": "Seats.io API region identifier (e.g. NA, EU, SA, OC)",
          "default": "NA"
        },
        "HoldExpirationInMinutes": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Hold token expiration in minutes. When null, uses the default configured in the Seats.io dashboard."
        }
      },
      "description": "Seats.io API configuration",
      "required": [
        "SecretKey"
      ]
    },
    "Cors": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "PolicyName": {
          "type": [
            "string",
            "null"
          ],
          "description": "CORS policy name registered in the pipeline.",
          "default": "XBOLPolicy"
        },
        "AcceptedOrigins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Origins allowed to call the API (exact match). Leave empty to disable app-level CORS."
        }
      },
      "description": "Cross-origin policy registered in the HTTP pipeline"
    },
    "BackgroundJobs": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "ConnectionString": {
          "type": "string",
          "description": "PostgreSQL connection string for Hangfire storage"
        }
      },
      "description": "Hangfire background-job storage configuration",
      "required": [
        "ConnectionString"
      ]
    },
    "EvoSettings": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "APIPassword": {
          "type": "string",
          "description": "API password provided by EVO Payments"
        },
        "MerchantId": {
          "type": "string",
          "description": "Merchant identifier assigned by EVO Payments"
        },
        "Version": {
          "type": "string",
          "description": "REST API version of the EVO Payments gateway"
        }
      },
      "description": "EVO Payments gateway configuration",
      "required": [
        "APIPassword",
        "MerchantId",
        "Version"
      ]
    }
  },
  "type": "object"
}