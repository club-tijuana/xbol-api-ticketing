{
    "$schema": "./appsettings.schema.json",
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "DefaultExchangeRate": {
        "Value": 20
    },
    "PaymentLink": {
        "Url": "https://pwrticket.mx/client/paymentLink/{paymentLinkCode}"
    },
    "EmailTemplate": {
        "HelpUrl": "/help",
        "SupportUrl": "/support",
        "SupportEmail": "soporte@pwrticket.mx",
        "PublicTermsAndConditionsUrl": "/termsandconditions"
    }
}
